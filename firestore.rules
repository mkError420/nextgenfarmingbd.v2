rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safe Default
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitives
    function isValidId(id) { return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null && request.auth.token.email_verified == true; }
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }

    // Admin Collection
    function isValidAdmin(data) {
      return data.keys().hasAll(['email', 'role', 'createdAt']) &&
             data.size() == 3 &&
             data.email is string && data.email.size() <= 200 &&
             data.role is string && data.role == 'admin' &&
             data.createdAt is number && data.createdAt > 0;
    }

    match /admins/{adminId} {
      // Only existing admins can read the admin list
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == adminId);
      
      // Allow specific admin email to bootstrap themselves
      allow create: if isSignedIn() && 
                    request.auth.uid == adminId && 
                    request.auth.token.email == 'mk.rabbani.cse@gmail.com' && 
                    isValidAdmin(incoming());
                    
      allow update, delete: if false;
    }

    // Product Collection
    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'price', 'category', 'createdAt', 'updatedAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.price is number && data.price >= 0 &&
             data.category is string && data.category.size() <= 100 &&
             data.createdAt is number && data.createdAt > 0 &&
             data.updatedAt is number && data.updatedAt > 0;
    }
    
    function isValidProductUpdate(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.price is number && data.price >= 0 &&
             data.category is string && data.category.size() <= 100 &&
             data.updatedAt is number && data.updatedAt >= existing().createdAt &&
             data.createdAt == existing().createdAt;
    }

    match /products/{productId} {
      allow read: if true; // Public can read products
      allow create: if isAdmin() && isValidId(productId) && isValidProduct(incoming());
      allow update: if isAdmin() && isValidId(productId) && isValidProductUpdate(incoming());
      allow delete: if isAdmin() && isValidId(productId);
    }

    // Order Collection
    function isValidOrder(data) {
      return data.keys().hasAll(['customerName', 'phone', 'address', 'items', 'totalAmount', 'status', 'createdAt', 'updatedAt']) &&
             data.customerName is string && data.customerName.size() <= 200 &&
             data.phone is string && data.phone.size() <= 20 &&
             data.address is string && data.address.size() <= 500 &&
             data.items is list && data.items.size() > 0 && data.items.size() <= 100 &&
             data.totalAmount is number && data.totalAmount >= 0 &&
             data.status == 'pending' &&
             data.createdAt is number && data.createdAt > 0 &&
             data.updatedAt is number && data.updatedAt >= data.createdAt;
    }

    function isValidOrderUpdate(data) {
      return data.status is string && data.status.matches('^(pending|processing|shipped|delivered|cancelled)$') &&
             data.updatedAt is number && data.updatedAt >= existing().createdAt &&
             data.createdAt == existing().createdAt;
    }

    match /orders/{orderId} {
      // Admins can read all orders, users can read their own if auth is present (though we allow anonymous order placement)
      // Since it's public ecommerce, maybe restrict to admin only for list, or by customer token.
      // We will restrict read to admins. Customers wait for email/SMS.
      allow read: if isAdmin(); 
      // Anyone can create an order (no auth needed for public checkout)
      allow create: if isValidId(orderId) && isValidOrder(incoming());
      allow update: if isAdmin() && isValidOrderUpdate(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']);
      allow delete: if false; // Orders are immutable/cancellable but not deletable
    }
    // Category Collection
    function isValidCategory(data) {
      return data.keys().hasAll(['name', 'type', 'createdAt', 'updatedAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.type is string && data.type.matches('^(product|blog)$') &&
             data.createdAt is number && data.createdAt > 0 &&
             data.updatedAt is number && data.updatedAt >= data.createdAt;
    }
    
    function isValidCategoryUpdate(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.type is string && data.type.matches('^(product|blog)$') &&
             data.updatedAt is number && data.updatedAt >= existing().createdAt &&
             data.createdAt == existing().createdAt;
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(categoryId) && isValidCategory(incoming());
      allow update: if isAdmin() && isValidId(categoryId) && isValidCategoryUpdate(incoming());
      allow delete: if isAdmin() && isValidId(categoryId);
    }

    // Blog Collection
    function isValidBlog(data) {
      return data.keys().hasAll(['title', 'content', 'createdAt', 'updatedAt']) &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             data.content is string && data.content.size() > 0 && data.content.size() <= 50000 &&
             data.createdAt is number && data.createdAt > 0 &&
             data.updatedAt is number && data.updatedAt >= data.createdAt;
    }
    
    function isValidBlogUpdate(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             data.content is string && data.content.size() > 0 && data.content.size() <= 50000 &&
             data.updatedAt is number && data.updatedAt >= existing().createdAt &&
             data.createdAt == existing().createdAt;
    }

    match /blogs/{blogId} {
      allow read: if true;
      allow list: if true;
      allow create: if isAdmin() && isValidId(blogId) && isValidBlog(incoming());
      allow update: if isAdmin() && isValidId(blogId) && isValidBlogUpdate(incoming());
      allow delete: if isAdmin() && isValidId(blogId);
    }
  }
}
